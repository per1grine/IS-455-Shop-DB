<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Student Shop</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/StudentShopApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="border-bottom app-shell">
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">
                <a class="navbar-brand fw-semibold" asp-controller="Store" asp-action="Index">Student Shop</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-controller="Store" asp-action="SelectCustomer">Select Customer</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Store" asp-action="Dashboard">Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Store" asp-action="PlaceOrder">Place Order</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Store" asp-action="Orders">Orders</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Store" asp-action="WarehousePriority">Warehouse Priority</a></li>
                    </ul>
                    <span class="navbar-text small text-white-50">@ViewBag.ActiveCustomerLabel</span>
                </div>
            </div>
        </nav>
    </header>

    <main class="container py-4">
        @if (TempData["StatusMessage"] is string statusMessage)
        {
            <div class="alert alert-success">@statusMessage</div>
        }
        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="alert alert-danger">@errorMessage</div>
        }
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
