@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="mb-4">
    <p class="form-section-title mb-2">Customer Dashboard</p>
    <h1 class="h2 mb-1">@Model.Customer.FullName</h1>
    <p class="text-muted mb-0">@Model.Customer.Email | @Model.Customer.City, @Model.Customer.State | @Model.Customer.Segment / @Model.Customer.LoyaltyTier</p>
</section>

<section class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="summary-card">
            <div class="metric-label">Total Orders</div>
            <div class="metric-value">@Model.Customer.OrderCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="summary-card">
            <div class="metric-label">Total Spent</div>
            <div class="metric-value">@Model.Customer.TotalSpent.ToString("C0")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="summary-card">
            <div class="metric-label">Average Order</div>
            <div class="metric-value">@Model.Customer.AverageOrderTotal.ToString("C0")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="summary-card">
            <div class="metric-label">Last Order</div>
            <div class="metric-value fs-5">@(!string.IsNullOrWhiteSpace(Model.Customer.LastOrderDate) ? Model.Customer.LastOrderDate : "No orders")</div>
        </div>
    </div>
</section>

<section class="page-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="h4 mb-1">Recent orders</h2>
            <p class="text-muted mb-0">Newest purchases for the selected customer.</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-primary" asp-action="Orders">View All Orders</a>
            <a class="btn btn-primary" asp-action="PlaceOrder">Place New Order</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Order</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Payment</th>
                    <th>Device</th>
                    <th>Priority</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @if (Model.RecentOrders.Count == 0)
            {
                <tr><td colspan="7" class="text-muted py-4">No orders yet for this customer.</td></tr>
            }
            else
            {
                @foreach (var order in Model.RecentOrders)
                {
                    <tr>
                        <td class="fw-semibold">#@order.OrderId</td>
                        <td>@order.OrderDateTime</td>
                        <td>@order.OrderTotal.ToString("C")</td>
                        <td>@order.PaymentMethod</td>
                        <td>@order.DeviceType</td>
                        <td><span class="badge badge-soft">@order.PriorityBucket (@(order.PriorityScore?.ToString("0.0") ?? "-"))</span></td>
                        <td><a class="btn btn-sm btn-outline-secondary" asp-action="OrderDetail" asp-route-orderId="@order.OrderId">Details</a></td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>
